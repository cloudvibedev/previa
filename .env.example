# ------------------------------
# Previa - Environment Example
# ------------------------------

# Global logging level used by tracing_subscriber::EnvFilter
RUST_LOG=info

# ==============================
# Orchestrator (previa-main)
# ==============================

# SQLite connection string for orchestrator database
ORCHESTRATOR_DATABASE_URL=sqlite://orchestrator.db

# Estimated requests/sec capacity per runner for node planning
RUNNER_RPS_PER_NODE=1000

# Comma-separated runner endpoints
# Example with one runner:
RUNNER_ENDPOINTS=http://127.0.0.1:55880
# Example with multiple runners:
# RUNNER_ENDPOINTS=http://127.0.0.1:55880,http://127.0.0.1:55881,http://127.0.0.1:55882

# HTTP bind config for orchestrator
ADDRESS=0.0.0.0
PORT=5588

# ==============================
# Runner (previa-runner)
# ==============================

# If you run runner separately, override PORT accordingly (e.g. 7373, 7374...)
# ADDRESS=0.0.0.0
# PORT=55880
